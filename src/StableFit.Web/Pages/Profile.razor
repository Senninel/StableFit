@page "/profile"
@inject HttpClient Http
@inject NavigationManager NavManager
@inject ISnackbar Snackbar

<PageTitle>My Profile - StableFit</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8">
    <MudCard Elevation="3">
        <MudCardHeader Class="pb-0">
            <CardHeaderContent>
                <MudText Typo="Typo.h5" Color="Color.Primary" Class="font-weight-bold">
                    @(IsNewProfile ? "Create Your Fitness Profile" : "Edit Your Profile")
                </MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            @if (IsLoadingInitial)
            {
                <div class="d-flex justify-content-center my-8">
                    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                </div>
            }
            else
            {
                @if (!string.IsNullOrEmpty(GeneralError))
                {
                    <MudAlert Severity="Severity.Error" Class="mb-4">@GeneralError</MudAlert>
                }

                <EditForm Model="Model" OnValidSubmit="SaveProfile">
                    <DataAnnotationsValidator />
                    
                    @if (IsNewProfile)
                    {
                        <MudAlert Severity="Severity.Info" Class="mb-4">
                            Welcome! Please set up your initial profile to continue.
                        </MudAlert>

                        <MudGrid>
                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="CreateRequest.Name" 
                                              Label="Full Name" 
                                              Variant="Variant.Outlined" 
                                              For="@(() => CreateRequest.Name)"
                                              Error="@HasError("Name")"
                                              ErrorText="@GetErrorText("Name")" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="CreateRequest.Username" 
                                              Label="Username" 
                                              Variant="Variant.Outlined" 
                                              For="@(() => CreateRequest.Username)"
                                              Error="@HasError("Username")"
                                              ErrorText="@GetErrorText("Username")" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField @bind-Value="CreateRequest.Email" 
                                              Label="Email" 
                                              InputType="InputType.Email" 
                                              Variant="Variant.Outlined" 
                                              For="@(() => CreateRequest.Email)"
                                              Error="@HasError("Email")"
                                              ErrorText="@GetErrorText("Email")" />
                            </MudItem>
                        </MudGrid>
                        <MudDivider Class="my-6" />
                    }

                    <MudGrid>
                        <MudItem xs="12">
                            <MudTextField @bind-Value="Model.Bio" 
                                          Label="Bio" 
                                          Lines="3" 
                                          Variant="Variant.Outlined" 
                                          Placeholder="Tell us about your fitness journey..."
                                          For="@(() => Model.Bio)"
                                          Error="@HasError("Bio")"
                                          ErrorText="@GetErrorText("Bio")" />
                        </MudItem>

                        <MudItem xs="12" sm="4">
                            <MudNumericField @bind-Value="Model.AgeYears" 
                                             Label="Age (Years)" 
                                             Variant="Variant.Outlined" 
                                             Min="0" Max="120"
                                             For="@(() => Model.AgeYears)"
                                             Error="@HasError("AgeYears")"
                                             ErrorText="@GetErrorText("AgeYears")" />
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudNumericField @bind-Value="Model.WeightKg" 
                                             Label="Weight (Kg)" 
                                             Variant="Variant.Outlined" 
                                             Min="0.0"
                                             For="@(() => Model.WeightKg)"
                                             Error="@HasError("WeightKg")"
                                             ErrorText="@GetErrorText("WeightKg")" />
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudSelect T="FitnessGoal?" 
                                       @bind-Value="Model.Goal" 
                                       Label="Primary Goal" 
                                       Variant="Variant.Outlined" 
                                       AnchorOrigin="Origin.BottomCenter">
                                <MudSelectItem T="FitnessGoal?" Value="@((FitnessGoal?)FitnessGoal.WeightLoss)">
                                    <MudIcon Icon="@Icons.Material.Filled.TrendingDown" Class="mr-2" Size="Size.Small"/> Weight Loss
                                </MudSelectItem>
                                <MudSelectItem T="FitnessGoal?" Value="@((FitnessGoal?)FitnessGoal.MuscleGain)">
                                    <MudIcon Icon="@Icons.Material.Filled.FitnessCenter" Class="mr-2" Size="Size.Small"/> Muscle Gain
                                </MudSelectItem>
                                <MudSelectItem T="FitnessGoal?" Value="@((FitnessGoal?)FitnessGoal.MaintainWeight)">
                                    <MudIcon Icon="@Icons.Material.Filled.TrendingFlat" Class="mr-2" Size="Size.Small"/> Maintain Weight
                                </MudSelectItem>
                            </MudSelect>
                        </MudItem>

                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle1" Class="mb-2">Workout Schedule (Days of Week)</MudText>
                            <div class="d-flex flex-wrap gap-4">
                                @foreach (DayOfWeek day in Enum.GetValues(typeof(DayOfWeek)))
                                {
                                    <MudCheckBox T="bool" 
                                                 Value="@Model.ScheduleDays.Contains(day)" 
                                                 ValueChanged="@((bool val) => ToggleDay(day, val))" 
                                                 Label="@day.ToString()" 
                                                 Color="Color.Primary" />
                                }
                            </div>
                            @if (HasError("ScheduleDays"))
                            {
                                <MudText Color="Color.Error" Typo="Typo.caption">@GetErrorText("ScheduleDays")</MudText>
                            }
                        </MudItem>
                    </MudGrid>

                    <div class="d-flex justify-space-between align-center mt-8">
                        <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="Logout">Logout</MudButton>
                        <MudButton ButtonType="ButtonType.Submit" 
                                   Variant="Variant.Filled" 
                                   Color="Color.Primary" 
                                   Disabled="@IsSaving">
                            @if (IsSaving)
                            {
                                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                                <MudText Class="ms-2">Saving...</MudText>
                            }
                            else
                            {
                                <MudText>Save Profile</MudText>
                            }
                        </MudButton>
                    </div>
                </EditForm>
            }
        </MudCardContent>
    </MudCard>
</MudContainer>

@code {
    private UpdateProfileRequest Model = new();
    private CreateProfileRequest CreateRequest = new();
    
    private bool IsLoadingInitial = true;
    private bool IsSaving = false;
    private bool IsNewProfile = false;
    private Dictionary<string, string[]> ApiErrors = new();
    private string? GeneralError;

    protected override async Task OnInitializedAsync()
    {
        await LoadProfile();
    }

    private bool HasError(string field) => ApiErrors.ContainsKey(field);
    private string GetErrorText(string field) => HasError(field) ? string.Join(", ", ApiErrors[field]) : string.Empty;

    private async Task LoadProfile()
    {
        try
        {
            var response = await Http.GetAsync("api/user-profiles/me");
            
            if (response.IsSuccessStatusCode)
            {
                var profile = await response.Content.ReadFromJsonAsync<UserProfileDto>();
                if (profile != null)
                {
                    IsNewProfile = false;
                    Model.Bio = profile.Bio;
                    Model.Goal = profile.Goal;
                    Model.ScheduleDays = profile.ScheduleDays ?? new List<DayOfWeek>();
                    Model.AgeYears = profile.AgeYears;
                    Model.WeightKg = profile.WeightKg;
                }
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                IsNewProfile = true;
                
                var authMeResponse = await Http.GetAsync("api/auth/me");
                if (authMeResponse.IsSuccessStatusCode)
                {
                    var authMe = await authMeResponse.Content.ReadFromJsonAsync<UserInfo>();
                    if (authMe != null)
                    {
                        CreateRequest.Email = authMe.Email ?? "";
                        CreateRequest.Username = authMe.Username ?? "";
                        CreateRequest.Name = authMe.Username ?? "";
                    }
                }
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                NavManager.NavigateTo("/login");
            }
        }
        catch (Exception ex)
        {
            GeneralError = $"Failed to load profile: {ex.Message}";
        }
        finally
        {
            IsLoadingInitial = false;
        }
    }

    private void ToggleDay(DayOfWeek day, bool isChecked)
    {
        if (isChecked && !Model.ScheduleDays.Contains(day))
        {
            Model.ScheduleDays.Add(day);
        }
        else if (!isChecked && Model.ScheduleDays.Contains(day))
        {
            Model.ScheduleDays.Remove(day);
        }
    }

    private async Task SaveProfile()
    {
        IsSaving = true;
        ApiErrors.Clear();
        GeneralError = null;

        try
        {
            if (IsNewProfile)
            {
                var createResponse = await Http.PostAsJsonAsync("api/user-profiles", CreateRequest);
                if (!createResponse.IsSuccessStatusCode)
                {
                    await HandleValidationErrors(createResponse);
                    return;
                }
                IsNewProfile = false;
            }

            var updateResponse = await Http.PutAsJsonAsync("api/user-profiles/me", Model);
            if (updateResponse.IsSuccessStatusCode)
            {
                Snackbar.Add("Profile saved successfully!", Severity.Success);
            }
            else
            {
                await HandleValidationErrors(updateResponse);
            }
        }
        catch (Exception ex)
        {
            GeneralError = $"Network error: {ex.Message}";
        }
        finally
        {
            IsSaving = false;
        }
    }

    private async Task HandleValidationErrors(HttpResponseMessage response)
    {
        var errorContent = await response.Content.ReadFromJsonAsync<ValidationProblemDetails>();
        if (errorContent?.Errors != null)
        {
            ApiErrors = errorContent.Errors;
        }
        else
        {
            GeneralError = $"An error occurred: {response.StatusCode}";
        }
    }

    private async Task Logout()
    {
        await Http.PostAsync("api/auth/logout", null);
        NavManager.NavigateTo("/login");
    }

    public class ValidationProblemDetails
    {
        public Dictionary<string, string[]>? Errors { get; set; }
    }
}
