@page "/login"
@inject HttpClient Http
@inject NavigationManager NavManager

<PageTitle>Login - StableFit</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-16">
    <MudCard Elevation="3">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h5" Align="Align.Center" Color="Color.Primary" Class="font-weight-bold">Login to StableFit</MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            @if (!string.IsNullOrEmpty(GeneralError))
            {
                <MudAlert Severity="Severity.Error" Class="mb-4">@GeneralError</MudAlert>
            }

            <EditForm Model="Model" OnValidSubmit="HandleLogin">
                <DataAnnotationsValidator />
                
                <MudTextField @bind-Value="Model.Email" 
                              Label="Email" 
                              Variant="Variant.Outlined" 
                              Class="mb-4"
                              For="@(() => Model.Email)"
                              Error="@HasError("Email")"
                              ErrorText="@GetErrorText("Email")" />

                <MudTextField @bind-Value="Model.Password" 
                              Label="Password" 
                              InputType="InputType.Password" 
                              Variant="Variant.Outlined" 
                              Class="mb-6"
                              For="@(() => Model.Password)"
                              Error="@HasError("Password")"
                              ErrorText="@GetErrorText("Password")" />

                <MudButton ButtonType="ButtonType.Submit" 
                           Variant="Variant.Filled" 
                           Color="Color.Primary" 
                           Size="Size.Large" 
                           FullWidth="true" 
                           Disabled="@IsLoading">
                    @if (IsLoading)
                    {
                        <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                        <MudText Class="ms-2">Logging in...</MudText>
                    }
                    else
                    {
                        <MudText>Login</MudText>
                    }
                </MudButton>
            </EditForm>
            
            <MudText Align="Align.Center" Class="mt-4">
                Don't have an account? <MudLink Href="/register" Color="Color.Primary">Register here</MudLink>.
            </MudText>
        </MudCardContent>
    </MudCard>
</MudContainer>

@code {
    private LoginRequest Model = new();
    private bool IsLoading = false;
    private Dictionary<string, string[]> ApiErrors = new();
    private string? GeneralError;

    private bool HasError(string field) => ApiErrors.ContainsKey(field);
    private string GetErrorText(string field) => HasError(field) ? string.Join(", ", ApiErrors[field]) : string.Empty;

    private async Task HandleLogin()
    {
        IsLoading = true;
        ApiErrors.Clear();
        GeneralError = null;

        try
        {
            var response = await Http.PostAsJsonAsync("api/auth/login", Model);
            
            if (response.IsSuccessStatusCode)
            {
                NavManager.NavigateTo("/profile");
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                GeneralError = "Invalid email or password.";
            }
            else
            {
                var errorContent = await response.Content.ReadFromJsonAsync<ValidationProblemDetails>();
                if (errorContent?.Errors != null)
                {
                    ApiErrors = errorContent.Errors;
                }
                else
                {
                    GeneralError = "An unknown error occurred during login.";
                }
            }
        }
        catch (Exception ex)
        {
            GeneralError = $"Network error: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }

    public class ValidationProblemDetails
    {
        public Dictionary<string, string[]>? Errors { get; set; }
    }
}
