@page "/"

<PageTitle>StableFit - The Future of Fitness</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-16">
    <MudGrid Justify="Justify.Center" AlignItems="AlignItems.Center">
        <!-- Hero Section -->
        <MudItem xs="12" md="8" Class="text-center mb-16">
            <MudText Typo="Typo.h1" Color="Color.Primary" Class="font-weight-bold mb-4">
                The Future of Fitness with AI
            </MudText>
            <MudText Typo="Typo.h5" Class="mb-8" Style="color: var(--mud-palette-text-primary);">
                StableFit brings Gale-Shapley matching, computer vision movement correction, and smart nutrition into one seamless platform.
            </MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Class="mr-4" Href="/register">
                Get Started
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Large" Href="/login">
                Login
            </MudButton>
        </MudItem>

        <!-- Features Section -->
        <MudItem xs="12">
            <MudGrid Justify="Justify.Center" Spacing="4">
                <!-- Feature 1 -->
                <MudItem xs="12" sm="4">
                    <MudCard Elevation="3" Style="height: 100%;">
                        <MudCardContent Class="text-center">
                            <MudIcon Icon="@Icons.Material.Filled.Group" Color="Color.Primary" Size="Size.Large" Class="mb-4" Style="font-size: 4rem;" />
                            <MudText Typo="Typo.h6" Class="font-weight-bold mb-2">Gale-Shapley Matching</MudText>
                            <MudText Typo="Typo.body2">
                                Find the perfect workout partner based on fitness goals, location proximity, and workout schedule.
                            </MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                
                <!-- Feature 2 -->
                <MudItem xs="12" sm="4">
                    <MudCard Elevation="3" Style="height: 100%;">
                        <MudCardContent Class="text-center">
                            <MudIcon Icon="@Icons.Material.Filled.Videocam" Color="Color.Primary" Size="Size.Large" Class="mb-4" Style="font-size: 4rem;" />
                            <MudText Typo="Typo.h6" Class="font-weight-bold mb-2">AI Movement Correction</MudText>
                            <MudText Typo="Typo.body2">
                                Advanced MediaPipe integration detects 33 body landmarks to provide real-time form feedback and prevent injury.
                            </MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                
                <!-- Feature 3 -->
                <MudItem xs="12" sm="4">
                    <MudCard Elevation="3" Style="height: 100%;">
                        <MudCardContent Class="text-center">
                            <MudIcon Icon="@Icons.Material.Filled.Restaurant" Color="Color.Primary" Size="Size.Large" Class="mb-4" Style="font-size: 4rem;" />
                            <MudText Typo="Typo.h6" Class="font-weight-bold mb-2">Smart Nutrition</MudText>
                            <MudText Typo="Typo.body2">
                                Track your daily macros and calories with ease, powered by industry-leading nutrition APIs.
                            </MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            </MudGrid>
        </MudItem>
    </MudGrid>
</MudContainer>
